{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "liumai",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-01",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
